Options -Indexes

# Force HTTPS — works both with direct SSL and behind CDN/proxy (Cloudflare)
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Direct SSL termination
    RewriteCond %{HTTPS} off
    # OR: proxy / CDN passes X-Forwarded-Proto (Cloudflare, Nginx, etc.)
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Protect sensitive files
<FilesMatch "(^\.env|composer\.(json|lock)|\.gitignore)">
    Require all denied
</FilesMatch>

<FilesMatch "\.(log|sql)$">
    Require all denied
</FilesMatch>

# Block PHP execution in uploads directory
# NOTE: FilesMatch with relative paths does NOT reliably block subdirectories in .htaccess.
# A dedicated uploads/.htaccess (php_flag engine off) is the correct approach.
# See: uploads/.htaccess

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://maps.googleapis.com https://maps.gstatic.com https://fonts.googleapis.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https://maps.googleapis.com https://maps.gstatic.com https://streetviewpixels-pa.googleapis.com; font-src 'self' https://fonts.gstatic.com https://unpkg.com; connect-src 'self'; frame-src 'self' https://lookerstudio.google.com https://maps.google.com https://www.youtube.com https://youtube.com https://youtu.be; frame-ancestors 'none';"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# index.html MUST NOT be cached — it contains the ?v= cache-busting params
<FilesMatch "^index\.html$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </IfModule>
</FilesMatch>

# JS/CSS: always revalidate with server (304 if unchanged, full download if changed)
# This eliminates sole dependency on ?v= params — Chrome MUST check the server every time.
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# Images: moderate cache (1 month) — images change rarely
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# Rewrite rules — route all requests to index.html (SPA)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /ERP/

    # API requests → pass through to PHP
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^api/(.*)$ api/router.php [L,QSA]

    # Static files → serve directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(?!api/)(.*)$ index.html [L]
</IfModule>
