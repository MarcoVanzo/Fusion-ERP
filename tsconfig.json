{
  "compilerOptions": {
    /* Language & Environment */
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    
    /* Type Checking */
    "strict": false,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    
    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@core/*": ["js/core/*"],
      "@modules/*": ["js/modules/*"],
      "@api/*": ["js/api/*"]
    },
    
    /* Output — Disabled: we use Vite for builds, not tsc */
    "outDir": "./dist",
    "declaration": false
  },
  "include": [
    "js/**/*.ts",
    "js/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "vendor",
    "fusion-website"
  ]
}
