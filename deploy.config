#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# Fusion ERP — Deploy Configuration
# Questo file viene letto da deploy.sh e deploy.py
# ═══════════════════════════════════════════════════════════════

# ── Identity ──
PROJECT_NAME="Fusion ERP"
GITHUB_REPO="MarcoVanzo/Fusion-ERP"
DEPLOY_BRANCH="main"

# ── URLs ──
DEPLOY_URL="https://www.fusionteamvolley.it/ERP/deploy_update.php"
APP_URL="https://www.fusionteamvolley.it/ERP"
HEALTH_URL=""
PING_URL="https://www.fusionteamvolley.it/ERP/ping.php"
MIGRATE_URL="https://www.fusionteamvolley.it/ERP/api/router.php?module=admin&action=migrate"

# ── Credentials ──
ENV_FILE=".env"

# ── Features ──
HAS_REACT_APPS=true
REACT_APPS="fusion-website fusion-erp-react"
HAS_SERVICE_WORKER=false
HAS_PHPSTAN=true
HAS_STRESS_TEST=true

# ── FTP Fallback ──
FTP_HOST_VAR="FTP_HOST"
FTP_USER_VAR="FTP_USER"
FTP_PASS_VAR="FTP_PASS"
FTP_DIR_VAR="FTP_DIR"
FTP_MAX_WORKERS=8
