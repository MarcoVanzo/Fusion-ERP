parameters:
    level: 5
    paths:
        - api/
    bootstrapFiles:
        - vendor/autoload.php
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        - '#on an unknown class PHPMailer\\\\PHPMailer\\\\PHPMailer#'
        - '#Access to property .* on an unknown class PHPMailer\\\\PHPMailer\\\\PHPMailer#'
