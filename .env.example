# ─── DATABASE ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fusion_erp
DB_USER=fusion_user
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# ─── APPLICATION ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost
APP_SECRET=CHANGE_ME_RANDOM_SECRET_32CHARS
DEFAULT_TENANT_ID=TNT_fusion

# ─── GOOGLE GEMINI AI ─────────────────────────────────────────────────────────
GEMINI_TOKEN=YOUR_GEMINI_TOKEN_HERE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ─── GOOGLE SERVICES ─────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
GOOGLE_SA_CLIENT_EMAIL=YOUR_SERVICE_ACCOUNT_EMAIL
GOOGLE_SA_PRIVATE_KEY=YOUR_SERVICE_ACCOUNT_PRIVATE_KEY
GOOGLE_DRIVE_FOLDER_ID=YOUR_GDRIVE_FOLDER_ID
GAS_PROXY_URL=YOUR_GAS_PROXY_URL

# ─── COGNITO FORMS API ────────────────────────────────────────────────────────
COGNITO_API_KEY=YOUR_COGNITO_API_KEY_HERE
COGNITO_FORM_ID=20
COGNITO_VIEW_ID=1

# ─── SCOUTING ─────────────────────────────────────────────────────────────────
SCOUTING_FUSION_API_KEY=YOUR_SCOUTING_FUSION_API_KEY
SCOUTING_FUSION_FORM_ID=YOUR_SCOUTING_FUSION_FORM_ID
SCOUTING_FUSION_VIEW_ID=YOUR_SCOUTING_FUSION_VIEW_ID
SCOUTING_NETWORK_API_KEY=YOUR_SCOUTING_NETWORK_API_KEY
SCOUTING_NETWORK_FORM_ID=YOUR_SCOUTING_NETWORK_FORM_ID
SCOUTING_NETWORK_VIEW_ID=YOUR_SCOUTING_NETWORK_VIEW_ID

# ─── E-COMMERCE ───────────────────────────────────────────────────────────────
ECOMMERCE_COGNITO_API_KEY=YOUR_ECOMMERCE_API_KEY
ECOMMERCE_FORM_ID=YOUR_ECOMMERCE_FORM_ID

# ─── SMTP / EMAIL ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=noreply@fusionteamvolley.it
SMTP_PASS=CHANGE_ME_APP_PASSWORD
SMTP_FROM_NAME="Fusion ERP"

# ─── SECURITY ─────────────────────────────────────────────────────────────────
SESSION_NAME=fusion_session
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=300
TRUSTED_PROXY=
PASSWORD_EXPIRY_DAYS=90
PASSWORD_MIN_LENGTH=10
PASSWORD_HISTORY_LIMIT=5

# ─── PDF & STORAGE ──────────────────────────────────────────────────────────────
PDF_STORAGE_PATH=/var/www/fusion/storage/pdfs/
UPLOAD_STORAGE_PATH=/var/www/fusion/storage/uploads/
BACKUP_STORAGE_PATH=/var/www/fusion/storage/backups/

# ─── MILEAGE ──────────────────────────────────────────────────────────────────
MILEAGE_RATE=0.25

# ─── IMPORT SECRET ────────────────────────────────────────────────────────
IMPORT_SECRET=CHANGE_ME_IMPORT_SECRET

# ─── META BUSINESS API ────────────────────────────────────────────────
META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET
META_REDIRECT_URI=https://your-domain.com/api/router.php?module=social&action=callback
META_CONFIG_ID=YOUR_META_CONFIG_ID

# ─── GOOGLE DRIVE BACKUP (OAuth2) ───────────────────────────────────────────────
GDRIVE_FOLDER_ID=YOUR_GDRIVE_FOLDER_ID
GDRIVE_CLIENT_ID=YOUR_GDRIVE_CLIENT_ID
GDRIVE_CLIENT_SECRET=YOUR_GDRIVE_CLIENT_SECRET
