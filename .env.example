# ─── DATABASE ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fusion_erp
DB_USER=fusion_user
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# ─── APPLICATION ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost
APP_SECRET=CHANGE_ME_RANDOM_SECRET_32CHARS

# ─── GOOGLE GEMINI AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ─── COGNITO FORMS ────────────────────────────────────────────────────────────
COGNITO_API_KEY=YOUR_COGNITO_API_KEY_HERE

# ─── GOOGLE MAPS ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ─── SMTP / EMAIL ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@fusionertclub.it
SMTP_PASS=CHANGE_ME_APP_PASSWORD
SMTP_FROM_NAME=Fusion ERP

# ─── SECURITY ─────────────────────────────────────────────────────────────────
SESSION_NAME=fusion_session
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=900

# ─── PDF ──────────────────────────────────────────────────────────────────────
PDF_STORAGE_PATH=/var/www/fusion/storage/pdfs/
UPLOAD_STORAGE_PATH=/var/www/fusion/storage/uploads/

# ─── MILEAGE ──────────────────────────────────────────────────────────────────
MILEAGE_RATE=0.25

# ─── GOOGLE DRIVE BACKUP (Service Account) ────────────────────────────────────
# Backup notturno off-site su Google Drive.
# Setup: console.cloud.google.com → IAM → Service Accounts → crea account → genera JSON key
# Condividi la cartella Drive con l'email del Service Account (permesso Editor)
GOOGLE_DRIVE_FOLDER_ID=YOUR_DRIVE_FOLDER_ID_HERE
GOOGLE_SA_CLIENT_EMAIL=fusion-backup@your-project.iam.gserviceaccount.com
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── WHATSAPP CLOUD API ───────────────────────────────────────────────────────
WHATSAPP_TOKEN=YOUR_TEMPORARY_OR_PERMANENT_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_BUSINESS_ACCOUNT_ID=YOUR_BUSINESS_ACCOUNT_ID
# App Secret (Settings → Basic → App Secret nella Console Meta for Developers)
# Usato per validare la firma HMAC-SHA256 del webhook
WHATSAPP_APP_SECRET=YOUR_META_APP_SECRET
# Token segreto da inserire anche nel pannello webhook di Meta (stringa libera)
WHATSAPP_VERIFY_TOKEN=fusion_erp_webhook_secret_2026

# ─── MAILERLITE ───────────────────────────────────────────────────────────────
# API Key generabile da: MailerLite Dashboard → Integrations → MailerLite API
# Formato: ml.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILERLITE_API_KEY=YOUR_MAILERLITE_API_KEY_HERE
