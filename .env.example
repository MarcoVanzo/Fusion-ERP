# ─── DATABASE ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fusion_erp
DB_USER=fusion_user
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# ─── APPLICATION ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost
APP_SECRET=CHANGE_ME_RANDOM_SECRET_32CHARS
DEFAULT_TENANT_ID=TNT_fusion

# ─── GOOGLE GEMINI AI ─────────────────────────────────────────────────────────
GEMINI_TOKEN=YOUR_GEMINI_TOKEN_HERE

# ─── COGNITO FORMS API ────────────────────────────────────────────────────────
COGNITO_API_KEY=YOUR_COGNITO_API_KEY_HERE
COGNITO_FORM_ID=20
COGNITO_VIEW_ID=1

# ─── SMTP / EMAIL ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=noreply@fusionteamvolley.it
SMTP_PASS=CHANGE_ME_APP_PASSWORD
SMTP_FROM_NAME="Fusion ERP"

# ─── SECURITY ─────────────────────────────────────────────────────────────────
SESSION_NAME=fusion_session
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=300
TRUSTED_PROXY=

# ─── PDF & STORAGE ──────────────────────────────────────────────────────────────
PDF_STORAGE_PATH=/var/www/fusion/storage/pdfs/
UPLOAD_STORAGE_PATH=/var/www/fusion/storage/uploads/
BACKUP_STORAGE_PATH=/var/www/fusion/storage/backups/

# ─── MILEAGE ──────────────────────────────────────────────────────────────────
MILEAGE_RATE=0.25

# ─── IMPORT SECRET ────────────────────────────────────────────────────────
IMPORT_SECRET=CHANGE_ME_IMPORT_SECRET

# ─── META BUSINESS API ────────────────────────────────────────────────
META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET
META_REDIRECT_URI=https://your-domain.com/api/router.php?module=social&action=callback
META_CONFIG_ID=YOUR_META_CONFIG_ID

# ─── GOOGLE DRIVE BACKUP (OAuth2) ───────────────────────────────────────────────
GDRIVE_FOLDER_ID=YOUR_GDRIVE_FOLDER_ID
GDRIVE_CLIENT_ID=YOUR_GDRIVE_CLIENT_ID
GDRIVE_CLIENT_SECRET=YOUR_GDRIVE_CLIENT_SECRET
GDRIVE_REFRESH_TOKEN=YOUR_GDRIVE_REFRESH_TOKEN

# ─── WHATSAPP CLOUD API ───────────────────────────────────────────────────────
WHATSAPP_TOKEN=YOUR_WHATSAPP_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_BUSINESS_ACCOUNT_ID=YOUR_BUSINESS_ACCOUNT_ID

# ─── STRIPE PAYMENTS ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# ─── MAILERLITE ───────────────────────────────────────────────────────────────
MAILERLITE_API_KEY=YOUR_MAILERLITE_API_KEY

# ─── VALD PERFORMANCE API ──────────────────────────────────────────────────────
VALD_CLIENT_ID=YOUR_VALD_CLIENT_ID
VALD_CLIENT_SECRET=YOUR_VALD_CLIENT_SECRET
VALD_USER_EMAIL=YOUR_VALD_EMAIL
VALD_ORG_ID=YOUR_VALD_ORG_ID

# ─── MIGRATIONS ───────────────────────────────────────────────────────────────
MIGRATION_TOKEN=CHANGE_ME_MIGRATION_TOKEN
