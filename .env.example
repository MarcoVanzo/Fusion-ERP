# ─── DATABASE ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fusion_erp
DB_USER=fusion_user
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# ─── APPLICATION ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost
APP_SECRET=CHANGE_ME_RANDOM_SECRET_32CHARS

# ─── GOOGLE GEMINI AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ─── GOOGLE MAPS ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ─── SMTP / EMAIL ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@fusionertclub.it
SMTP_PASS=CHANGE_ME_APP_PASSWORD
SMTP_FROM_NAME=Fusion ERP

# ─── SECURITY ─────────────────────────────────────────────────────────────────
SESSION_NAME=fusion_session
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=900

# ─── PDF ──────────────────────────────────────────────────────────────────────
PDF_STORAGE_PATH=/var/www/fusion/storage/pdfs/
UPLOAD_STORAGE_PATH=/var/www/fusion/storage/uploads/

# ─── MILEAGE ──────────────────────────────────────────────────────────────────
MILEAGE_RATE=0.25
