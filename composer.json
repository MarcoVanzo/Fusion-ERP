{
    "name": "fusionerp/fusion-erp",
    "description": "Fusion ERP — Sports Management System",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "mailerlite/mailerlite-php": "^1.0",
        "mpdf/mpdf": "^8.2",
        "nyholm/psr7": "^1.8",
        "phpmailer/phpmailer": "^6.9",
        "symfony/http-client": "^6.0|^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "FusionERP\\": "api/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.1.0"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    }
}
